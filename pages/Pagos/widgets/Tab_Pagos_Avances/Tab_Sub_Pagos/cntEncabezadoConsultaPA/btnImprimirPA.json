  "onClick": "{{\nstoreValue(\n    \"idPAImpresion\",\n    tblConsultaPA.selectedRow.id_pago\n)\n.then(() =>\n\n    Promise.all([\n\n        qryPAImprimir.run(),\n        qryPAImprimirDetalle.run()\n\n    ])\n\n)\n.then(async () => {\n\n    await storeValue(\n        \"paImpresion\",\n        qryPAImprimir.data?.[0]\n    );\n\n    await storeValue(\n        \"detallePAImpresion\",\n        qryPAImprimirDetalle.data || []\n    );\n\n    download(\n        JS_PA_Impresion.generarHTMLPA(),\n        `${qryPAImprimir.data?.[0]?.numero_pago}.html`,\n        \"text/html\"\n    );\n\n})\n.catch((err) => {\n\n    showAlert(\n        err.message,\n        \"error\"\n    );\n\n});\n}}",
